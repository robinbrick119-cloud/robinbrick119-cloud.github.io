<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="true">
  <code><![CDATA[breed [manders mander]
breed [frogs frog]
patches-own [salinity] ;0 is clean water, 1 is polluted, 2 is not water
turtles-own [habitat stage albino grownday fate measurements tutorial grew-up plotted] ; whether they live in clean or polluted water, where they are in life cycle, if albino, when they will become an adult, when they will die, what their final size will be in mm, whether or not this is a turtle created to display tutorial text, whether or not this turtle was alive at metamorphosis, and whether or not this turtle has moved. albino values are 0 (doesn't have,) 1 (has but won't survive,) 2 (has and is normal)
frogs-own [sex] ; 0 female, 1 male, 2 axanthic (sexual dimorphism won't show)
manders-own [birthdays born] ; days until birth, and whether or not this salamander actually hatched (distinguishes ghosts)
globals [coexistence] ; 0 for onlly one species, 1 for two species

; note to anyone reading this code, in NetLogo, "turtles" refers to any moving agent. This model does not have the animal turtles in it, and for its purposes, frogs and salamanders are both "turtles."

to setup
 ca
  reset-ticks ; standard setup procedures
  
  ask patches [set pcolor blue] ; aesthetic
  
  ask patches
  [ ifelse pycor > 0
      [ set salinity 0 ]
      [ set salinity 1] ] ; patches on the top half are clean of salt, and patches on the bottom are polluted. note: this data ended up going completely unused in the final version.
  
  ask patches [if pycor = 0 [set salinity 2]]
  ask patches [if pycor = 1 [set salinity 2]] ; the middle two lines are wall, and are neither clean nor polluted, as they are not water
  
  ask patches [if salinity = 2 [set pcolor gray]]
  ask n-of 150 patches [if salinity = 1 [set pcolor white]] ; aesthetic
  
  create-turtles 1 [set tutorial 1 set habitat 2 set color blue set xcor 43 set ycor 54 set label "Welcome, in this model, you will observe the growth of virtual amphibians over a "]
  create-turtles 1 [set tutorial 1 set habitat 2 set color blue set xcor 43 set ycor 49 set label "90 day period. Some will be born into pure freshwater pools, while others will    "]
  create-turtles 1 [set tutorial 1 set habitat 2 set color blue set xcor 43 set ycor 44 set label   "be born into pools polluted by salt. Add spotted salamanders, wood frogs, or     "]
  create-turtles 1 [set tutorial 1 set habitat 2 set color blue set xcor 43 set ycor 39 set label "both to your pools, and then click ''one day'' to begin! See what you can notice,  "]
  create-turtles 1 [set tutorial 1 set color blue set habitat 2  set xcor 43 set ycor 34 set label "and then click the ''questions'' button in the top right. You will likely need to run   "]
  create-turtles 1 [set tutorial 1 set color blue set habitat 2 set xcor 43 set ycor 29 set label   "the model multiple times to observe answers to all the questions. This is highly   "]
  create-turtles 1 [set tutorial 1 set color blue set xcor 43 set habitat 2 set ycor 24 set label    "encouraged! You can learn more by scrolling down to ''model info.'' If you have   "]
  create-turtles 1 [set tutorial 1 set color blue set xcor 43 set habitat 2 set ycor 19 set label                "further questions, suggestions, or encounter glitches, please email            "]
  create-turtles 1 [set tutorial 1 set color blue set xcor 43 set habitat 2 set ycor 14 set label                                                "robinbrick119@gmail.com. Thank you!                                    "]
  ask turtles [set heading 0]
  ask turtles [set heading 90]
  ask turtles [forward 6] ; turtles that will blend into the background, used to load text onto the screen

end


to spawn-manders
  ask turtles with [tutorial = 1] [die] ; removes tutorial text
  
  if count manders < 2000 
  [
    
    create-manders 100 [set shape "eyeball" set size 1 set color 32 set stage 0 set habitat 0] ; adds 100 salamander eggs, prepares them aesthetically, and sets values to 0 (these lines are unnecessary, as all created variables are 0 by default. they are in for my peace of mind.)
    
  
  create-manders 100 [set shape "eyeball" set size 1 set color 32 set stage 0 set habitat 1 ; adds 100 salamander eggs, prepares them aesthetically, and marks that they live in a polluted habitat. setting their stage to 0 is completely unnecessary, as they are created with all values at 0, but it's written in for my peace of mind.)
    ]
  
    ask manders [if random 4000 = 1 [ifelse random 3 = 1 [set albino 2][set albino 1]]] ; 1 in 4000 chance of beeing albino, of which, 2 of 3 will die no matter what. Numbers pulled from Mitchell et al.
    
    ask manders with [habitat = 0] [set birthdays 18 + random 13] ; salamanders in clean water will hatch anywhere from 18 to 30 days into the simulation
    
    ask manders with [habitat = 1] [set birthdays 19 + random 17] ; salamanders in polluted water will hatch anywhere from 19 to 35 days into the simulation. Numbers pulled from Ocampo et al.
    
    ask manders [plotting]
    
  ] ; only works if there are less than 1000 salamanders
end 

to spawn-frogs
  ask turtles with [tutorial = 1] [die]; removes tutorial text
  
 if count frogs < 2000 
  [
    
    create-frogs 100 [set shape "tadpole" set size 1 set color 32 set stage 1 set habitat 0  ; adds 100 tadpoles, prepares them aesthetically, and marks that them as larva. setting their habitat to 0 is completely unnecessary, as they are created with all values at 0, but it's written in for my peace of mind.)
      let min-y 3  
    let max-y 64  
    let random-y (min-y + (random-float (max-y - min-y)))
    set ycor random-y
    set xcor random-xcor ] ; in tandem, these lines make sure these frogs only spawn in the top, clean half
  
  create-frogs 100 [set shape "tadpole" set size 1 set color 32 set stage 1 set habitat 1 ; adds 100 tadpoles, prepares them aesthetically, marks them as larva, and marks that they live in a polluted habitat. 
    let min-y -64  
    let max-y -3 
    let random-y (min-y + (random-float (max-y - min-y)))
    set ycor random-y
    set xcor random-xcor ] ; in tandem, these lines make sure these frogs only spawn in the bottom, polluted half 
  
  ask frogs [if random 400 = 1 [ifelse random 100 = 1 [set albino 2][set albino 1]]] ; frogs have a 1 in 400 chance of being albino, but only 1% of them will survive when they reach adulthood, as this increases the risk of predation
  
  ask frogs [if albino > 0[set shape "tadpole-albino"]] ; makes albino tadpoles match aesthetically
    
    ask frogs [if random 2 = 1 [set sex 1]] ; gives frogs a 50% chance to be male (they are female by default)
    
    ask frogs [if random 450 = 1 [set sex 3]] ; gives frogs a 2.5% chance to have axanthism, which makes their sexual dimorphism unnoticeable.
    
    ask frogs [if sex = 3 [set color cyan]] ; makes axanthic frogs blue
   
    ask frogs with [habitat = 0] [set grownday 50 + random 11] ; tadpoles in clean water will metamorphize anywhere ffrom 50 to 60 days into the experiment
    
    ask frogs with [habitat = 1] [set grownday 64 + random 3] ; tadpoles in polluted water will metamorphize anywhere from 64 to 66 days into the experiment
    
    ask frogs with [habitat = 0] [set measurements (10 ^ (1.15 + random .05))]
    ask frogs with [habitat = 1] [set measurements (10 ^ (1.23 + random .03))] ; sets the final size of frogs based on environment, with numbers bein average body length from Ocampo et al
    
    ask frogs [plotting]
    
  ] ; only works if there are less than 1000 frogs
end

to plotting
  ask turtles with [(habitat = 0) and (plotted = 0)] [ let min-y 3  
    let max-y 64  
    let random-y (min-y + (random-float (max-y - min-y)))
    set ycor random-y
    set xcor random-xcor
  set plotted 1] 
  
  ask turtles with [(habitat = 1) and (plotted = 0)] [let min-y -64  
    let max-y -3 
    let random-y (min-y + (random-float (max-y - min-y)))
    set ycor random-y
    set xcor random-xcor 
  set plotted 1] ; makes sure that animals habitats are visually represented
  
  ask turtles with [(habitat = 0) and (ycor < 8) and (xcor < -27)] [ let min-y 3  
    let max-y 64  
    let random-y (min-y + (random-float (max-y - min-y)))
    set ycor random-y
    set xcor random-xcor
  set plotted 1] 

  ask turtles with [(habitat = 1) and (ycor < -59) and (xcor < -18)] [let min-y -64  
    let max-y -3 
    let random-y (min-y + (random-float (max-y - min-y)))
    set ycor random-y
    set xcor random-xcor 
  set plotted 1]; if the turtle fell right under the stream label, it will move
  
  ask turtles with [(habitat = 0) and (ycor < 8) and (xcor < -27)] [ let min-y 3  
    let max-y 64  
    let random-y (min-y + (random-float (max-y - min-y)))
    set ycor random-y
    set xcor random-xcor
  set plotted 1] 

  ask turtles with [(habitat = 1) and (ycor < -59) and (xcor < -18)] [let min-y -64  
    let max-y -3 
    let random-y (min-y + (random-float (max-y - min-y)))
    set ycor random-y
    set xcor random-xcor 
  set plotted 1]
  
  ask turtles with [(habitat = 0) and (ycor < 8) and (xcor < -27)] [ let min-y 3  
    let max-y 64  
    let random-y (min-y + (random-float (max-y - min-y)))
    set ycor random-y
    set xcor random-xcor
  set plotted 1] 

  ask turtles with [(habitat = 1) and (ycor < -59) and (xcor < -18)] [let min-y -64  
    let max-y -3 
    let random-y (min-y + (random-float (max-y - min-y)))
    set ycor random-y
    set xcor random-xcor 
  set plotted 1] ; repeats in case they end up in the same spot again
end

to day
  if ticks < 90 [tick] ; stops the expirement at 90 days
  
  if count manders > 0 [if count frogs > 0 [set coexistence 1]] ; if there are both salamanders and frogs, some calculations will be affected
  
  if ticks = 1 [
    
    ask manders with [habitat = 0] [ifelse coexistence = 0 [set grownday 50 + random 11][set grownday 57 + random 5]]
    
    ask manders with [habitat = 1] [ifelse coexistence = 0 [set grownday 68 + random 5][set grownday 60 + random 5]]
    
  
  
  if coexistence = 0 [ask frogs with [habitat = 0][ifelse random 6 = 1 [set fate 2 + random 9][ifelse random 5 = 1 [set fate 50 + random 11][if random 4 = 1 [set fate 10 + random 80]]]]] ; if frogs exist without salamanders, then the ones in clean water have a 1 in 6 chance of dying in the first 10 days, the survivors of which have a 1 in 5 chance of dying days 50 to 60, and the survivors of both these events have a 1 in 4 chance to die at any time after the first 10 days. This leaves half frogs to die at some point, with the numbers pulled from Sanzo et al.
  if coexistence = 0 [ask frogs with [habitat = 1][ifelse random 2 = 1 [set fate 2 + random 9][ifelse random 3 = 1 [set fate 50 + random 11][if random 2 = 1 [set fate 10 + random 80]]]]] ; if frogs exist without salamanders, then the ones in salt have a 50% chance of dying in the first 10 days, the survivors of which have a 1 in 3 chance of dying days 50 to 60, and the survivors of both these events have a 50% chance to die at any time after the first 10 days. This leaves 5/6 frogs to die at some point, with the numbers pulled from Sanzo et al.
  
  if coexistence = 1 [ask frogs with [habitat = 0] [if random 100 < 37 [set fate 100]]] ; with coexistence, frogs in clean water have a 37% survival rate, setting these ones to have a fate that will never come. these numbers are from Ocampo et al, reverse engineered from what was assumed to be a @ * arcsin(squarerooteP) equation.
  if coexistence = 1 [ask frogs with [habitat = 1] [if random 100 < 19 [set fate 100]]] ; with coexistence, frogs in polluted water have a 19% survival rate, setting these ones to have a fate that will never come. these numbers are from Ocampo et al, reverse engineered from what was assumed to be a @ * arcsin(squarerooteP) equation.
  if coexistence = 0 [ask manders with [habitat = 0] [if random 100 < 37 [set fate 100]]] ; salamanders in clean water with no tadpoles have a 37% survival rate, setting these ones to have a fate that will never come. these numbers are from Ocampo et al, reverse engineered from what was assumed to be a @ * arcsin(squarerooteP) equation.
  if coexistence = 0 [ask manders with [habitat = 1] [if random 100 < 12 [set fate 100]]] ; salamanders in polluted water with no tadpoles have a 12% survival rate, setting these ones to have a fate that will never come. these numbers are from Ocampo et al, reverse engineered from what was assumed to be a @ * arcsin(squarerooteP) equation.
  if coexistence = 1 [ask manders with [habitat = 0] [if random 100 < 19 [set fate 100]]] ; with coexistence, salamanders in clean water have a 19% survival rate, setting these ones to have a fate that will never come. these numbers are from Ocampo et al, reverse engineered from what was assumed to be a @ * arcsin(squarerooteP) equation.
  if coexistence = 1 [ask manders with [habitat = 1] [if random 100 < 4 [set fate 100]]] ; with coexistence, polluted water have a 4% survival rate, setting these ones to have a fate that will never come. these numbers are from Ocampo et al, reverse engineered from what was assumed to be a @ * arcsin(squarerooteP) equation.
  
  if coexistence = 1 [ask turtles with [fate < 100] [ifelse random 2 = 1 [set fate 2 + random 9]
    [ifelse random 3 = 1 [set fate 50 + random 11][set fate 10 + random 80]]]] ; with coexistence, amphibians that did not meet the survival rate in the above block have a 1/2 (or 3/6) chance to die in the first 10 days, 1/6 to die from days 50 to 60, and 1/2 (or 2/6) chance to die at any time after the first 10 days.
  
  if coexistence = 1 [ask turtles with [fate < 100] [ifelse random 2 = 1 [set fate 2 + random 9]
    [ifelse random 3 = 1 [set fate 50 + random 11][set fate 10 + random 80]]]] ; with coexistence, amphibians that did not meet the survival rate in the above block have a 1/2 (or 3/6) chance to die in the first 10 days, 1/6 to die from days 50 to 60, and 1/2 (or 2/6) chance to die at any time after the first 10 days.
  
  if coexistence = 0 [ask manders with [fate < 100] [ifelse random 2 = 1 [set fate 2 + random 9]
    [ifelse random 3 = 1 [set fate 50 + random 11][set fate 10 + random 80]]]] ; without coexistence, salamanders that did not meet the survival rate in the above block have a 1/2 (or 3/6) chance to die in the first 10 days, 1/6 to die from days 50 to 60, and 1/2 (or 2/6) chance to die at any time after the first 10 days. This does not reroll the fates of tadpoles living alone.
  
  if coexistence = 0 [
      ask manders with [habitat = 0] [set measurements (50 + random 5)]
    ask manders with [habitat = 1] [set measurements (44 + random 7)]
  ]
  
    if coexistence = 1 [
      ask manders with [habitat = 0] [set measurements (47 + random 6)]
    ask manders with [habitat = 1] [set measurements (33 + random 9)] ; sets salamander final size based on habitat and competition, with numbers pulled from Ocampo et al.'s finding on average length in mm
  ] 
    
  ] ; all of the above only happens at the beginning
  
  ask turtles with [fate = ticks] [set stage 3] ; if a turtle's coded day of death equals today, change into a ghost, and cease all growth related procedures
  
  ask turtles with [stage < 3] [set size 1 + (((measurements * (ticks / 90))) / 4)] ; turtles that are not ghosts grow, proportional to their established final size
  hatching
  growing
  death
end

to hatching
  ask manders with [stage < 3] [if birthdays = ticks [set born 1 set stage 1 set shape "salamander-larva"]] ; if a salamander's hatch time lines up with the current day, it gains the properties of a larva
  ask manders with [stage = 1] [if albino > 0 [set shape "salamander-larva-albino"]] ; albino larva have their sprites updated to reflect this
end

to growing
  ask manders with [(grownday = ticks) and (stage = 1)] [set grew-up 1 set stage 2 set shape "salamander"] ; larvae that are not dead grows up mechanically and aesthetically when time
  ask manders with [(stage = 2) and (albino = 1)] [set stage 3] ; albino larvae that were not going to survive now die
  ask manders with [(stage = 2) and (albino = 2)] [set shape "salamander-albino"] ; albino larvae that survive have their aesthetics updates
  ask frogs with [(grownday = ticks) and (stage = 1)] [set grew-up 1 set stage 2 set shape "frog"] ; larvae that are not dead grows up mechanically and aesthetically when time
  ask frogs with [(stage = 2) and (albino = 1)] [set stage 3]  ; albino larvae that were not going to survive now die
ask frogs with [(stage = 2) and (albino = 2)] [set shape "frog-albino"] ; albino larvae that survive have their aesthetics updates
ask frogs with [(sex = 0) and (stage = 2)] [set color 133] 
ask frogs with [(sex = 1) and (stage = 2)] [set color 131] ; frogs now display sexual dimorphism
end

to death
  ask turtles with [stage = 3] [set shape "ghost" set color 115] ; makes aesthetic changes to dead amphibians. mechanical changes come from their stage being set to 3
end

to week
  day
   day
      day
      day
    day
         day
             day ; performs the day procedure 7 times
end
    
to month
  week
  week
  week
  week
  day
  day ; performs the day procedure 30 times
      end
        
to skip
  while [ticks < 90] [day] ; performs the day procedure until 90 days has been reached
end

to hide-ghosts
  ask turtles with [stage = 3][hide-turtle]
  ask turtles with [stage < 3][show-turtle]
end

to show-ghosts
  ask turtles [show-turtle]
end

to show-ghosts-only
  ask turtles with [stage = 3][show-turtle]
  ask turtles with [stage < 3][hide-turtle]
end

to highlight-color-mutations
  ask turtles [hide-turtle]
  ask turtles with [albino > 0] [show-turtle]
  ask frogs with [sex = 3] [show-turtle]
end

to questions
 ask turtles [hide-turtle]
  clear-output
  output-print "1. Which habitat had fewer deaths?"
  output-print " "
  output-print "2. Which habitat had bigger salamanders?"
  output-print " "
  output-print "3. Which habitat had bigger frogs?"
  output-print " "
  output-print "4. Regardless of habitat, is there a difference of the survival rate of salamanders alone vs. salamanders"
  output-print "with frogs? What about frogs alone vs. frogs with salamanders?"
  output-print " "
  output-print "5. Do Salamanders reach adulthood faster or slower in the salty habitat? What about frogs?"
  output-print " "
  output-print "6. How can salt be a pollutant when it is a natural substance, and many animals live in the salty ocean?"
  output-print " "
  output-print "7. Some frogs are a lighter red, while others are a darker brown, can you guess or find out why that is?"
  output-print " "
  output-print "8. Did you see any albino (white) animals? Did they tend to survive to adulthood? Why or why not?"
  output-print " "
  output-print "9. Did you see any blue frogs? What about salamanders?"
  output-print " "
  output-print "10. Albino (white) and Axanthic (blue) animals are pretty rare, but it may not take long at all to see one"
 output-print "in this model. Why do you think that is?"
  output-print " "
  output-print "11. Do you think it would be easy to find an albino or axanthic animal in real life?"
  output-print " "
  output-print "12. Survival is random, so theoretically, the salty habitat could end up having a higher survival rate than"
  output-print "the clean habitat. Can you observe this? How would a rare event like this be different from a rare event like"
 output-print "an animal being born albino?"
  output-print " "
  
  create-turtles 1 [set tutorial 2 set color blue set xcor 43 set habitat 2 set ycor 31 set label "Please check the ''command center'' below the model. Thanks for playing :)"]
  ask turtles with [tutorial = 2][show-turtle]
end

to questions-answers
  clear-output
 ask turtles [hide-turtle]
  output-print "1. Which habitat had fewer deaths?"
  output-print " "
  output-print "The clean habitat should have fewer deaths."
  output-print " "
  output-print "2. Which habitat had bigger salamanders?"
  output-print " "
  output-print "The clean habitat has bigger salamanders."
  output-print " "
  output-print "3. Which habitat had bigger frogs?"
  output-print " "
  output-print "The frogs in the polluted habitat are bigger. This may seem odd, and some studies have found it inhibits"
  output-print "their growth, but others have found salty water to make frogs large and bloated (Hall et al. 2017) (Ocampo et al. 2022.)"
 output-print "What's clear is that salt pollution causes abnormal growth one way or another."
  output-print " "
  output-print "4. Regardless of habitat, is there a difference of the survival rate of salamanders alone vs. salamanders"
 output-print "with frogs? What about frogs alone vs. frogs with salamanders?"
  output-print " "
  output-print "The survival rate of both species will go down. This is because of competition. Adding more animal species"
  output-print "adds more demand for the same amount of food. In fact, animals will also compete with others of their own species,"
  output-print "however that has not been programmed into this model. Look up ''carrying capacity if you would like to learn more!''"
  output-print " "
  output-print "5. Do Salamanders reach adulthood faster or slower in the salty habitat? What about frogs?"
  output-print " "
  output-print "Frogs and salamanders both metamorphosize slower in salt polluted pools. This leaves them more vunerable"
  output-print "to predation in their earlier life stages."
  output-print " "
  output-print "6. How can salt be a pollutant when it is a natural substance, and many animals live in the salty ocean?"
  output-print " "
  output-print "Animals in habitats like the ocean or the sea have been living in salt water for millions of years, so they"
  output-print "are adapted to do so. Meanwhile, animals like frogs and salamanders have spent millions of years adapting to"
  output-print "freshwater, and their habitats have only become salty recently. This happens because road salt used in the" 
  output-print "winter time will end up in our streams and freshwater pools after it rains, and it stays there forever!"
  output-print " "
  output-print "7. Some frogs are a lighter red, while others are a darker brown, can you guess or find out why that is?"
  output-print " "
  output-print "The light red frogs are female, while the dark brown frogs are male. This is an example of" 
  output-print "''sexual dimorphism,'' which refers to males and females of a species having different appearances. Some" 
  output-print "other sexually dimorphic animals are lions or cardinals."
  output-print " "
  output-print "8. Did you see any albino (white) animals? Did they tend to survive to adulthood? Why or why not?"
  output-print " "
  output-print "Whether or not you saw an albino animal depends partially on luck, but mostly, how many animals you spawned" 
  output-print "in. These animals may die at adulthood, as they become more vunerable to predation. This is especially likely" 
  output-print "for frogs, where observations of albino adults are very, very limited."
  output-print " "
  output-print "9. Did you see any blue frogs? What about salamanders?"
  output-print " "
  output-print "You may have seen a blue frog, but you most definitely did not see a blue salamander. This is a trait called" 
  output-print "''axanthism,'' which interferes with an animal's ability to produce yellow pigment. This has been observed in"
  output-print "frogs at a rate of around 1/400 to 1/500, depending on factors like species and location, but almost never"
  output-print "appears in salamnaders."
  output-print " "
  output-print "10. Albino (white) and Axanthic (blue) animals are pretty rare, but it may not take long at all to see one"
  output-print "in this model. Why do you think that is?"
  output-print " "
  output-print "In this model, you can spawn in hundreds of animals at once. So while any one animal is unlikely to have"
  output-print "these mutations, it becomes highly likely that somewhere in the population, the mutation will occur. This"
  output-print "is one of the reasons ''sample size'' (how many individuals you're studying) is important in science. A" 
  output-print "high sample size makes it more likely to see all the unlikely things that can happen to one individual!"
  output-print " "
  output-print "11. Do you think it would be easy to find an albino or axanthic animal in real life?"
  output-print " "
  output-print "This would be much harder in real life than in the model, as instead of clicking a button, you would need"
  output-print "to go outside and find these animals, and the number you find would be much lower. Simulations cannot"
  output-print "capture everything about the scientific process!"
  output-print " "
  output-print "12. Survival is random, so theoretically, the salty habitat could end up having a higher survival rate than"
  output-print"the clean habitat. Can you observe this? How would a rare event like this be different from a rare event"
  output-print"like an animal being born albino?"
  output-print " "
  output-print "It is near impossible for the salty habitat to end up with a higher survival rate. This is also due to"
  output-print "sample size. The odds of an unlikely event happening to an entire population or sevral times over"
  output-print "are very, very low. Try to flip a coin and get tails 50 times in a row. I bet you can't, as the odds"
  output-print "of this are over 1 in a quadrillion."
  output-print " "
  
  create-turtles 1 [set tutorial 2 set color blue set xcor 43 set habitat 2 set ycor 31 set label "Please check the ''command center'' below the model. Thanks for playing :)"]
  ask turtles with [tutorial = 2][show-turtle]
end]]></code>
  <widgets>
    <view x="10" wrappingAllowedX="true" y="130" frameRate="30.0" minPycor="-64" height="654" showTickCounter="true" patchSize="5.0" fontSize="14" wrappingAllowedY="true" width="653" tickCounterLabel="days" maxPycor="64" updateMode="0" maxPxcor="64" minPxcor="-64"></view>
    <button x="695" y="20" height="35" disableUntilTicks="false" forever="false" kind="Observer" width="115" display="One day">day</button>
    <button x="815" y="20" height="35" disableUntilTicks="false" forever="false" kind="Observer" width="115" display="One week">week</button>
    <button x="935" y="20" height="35" disableUntilTicks="false" forever="false" kind="Observer" width="115" display="One month">Month</button>
    <button x="1055" y="20" height="36" disableUntilTicks="false" forever="false" kind="Observer" width="155" display="Skip to end">skip</button>
    <button x="695" y="55" height="36" disableUntilTicks="false" forever="false" kind="Observer" width="115" display="Hide deaths">hide-ghosts</button>
    <button x="815" y="55" height="36" disableUntilTicks="false" forever="false" kind="Observer" width="115" display="Show deaths">show-ghosts</button>
